# ---------------------------------------------------------------------------
# Cholla Billing Platform — environment
# Copy to `.env` for local dev. On Vercel, set these in Project → Settings → Env.
# ---------------------------------------------------------------------------

# Postgres connection string.
# Local docker-compose default:
DATABASE_URL="postgresql://cholla:cholla@localhost:5432/cholla?schema=public"
DIRECT_URL="postgresql://cholla:cholla@localhost:5432/cholla?schema=public"
# Vercel: use Vercel Postgres / Neon. Use the POOLED url for the app (serverless),
# and the DIRECT url for `prisma db push`/migrations/seed:
# DATABASE_URL="postgres://...-pooler.../verceldb?sslmode=require"
# DIRECT_URL="postgres://.../verceldb?sslmode=require"

# Secret used to sign the session cookie. Generate: `openssl rand -base64 32`
SESSION_SECRET="dev-only-change-me-in-production"

# Enable the demo "preview as role" switcher on the login screen (v1 parity).
# Set to "false" in production once real SSO is wired.
NEXT_PUBLIC_DEMO_ROLE_SWITCH="true"
